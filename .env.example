# Shared password gating the UI (signed-cookie session). Min 8 chars.
APP_PASSWORD=change-me

# One block per telemt instance. <ID> is an uppercase identifier
# (letters, digits, underscores) and becomes the instance id used in
# the UI/URLs (lowercased, underscores -> dashes).
#
# TELEMT_<ID>_BASE_URL    - base URL of the telemt Control API, e.g. http://10.0.0.2:9091
# TELEMT_<ID>_AUTH_HEADER - value sent as the Authorization header
# TELEMT_<ID>_LABEL       - optional display name (defaults to <ID>)

TELEMT_VPS1_BASE_URL=http://10.0.0.2:9091
TELEMT_VPS1_AUTH_HEADER=Bearer change-me
TELEMT_VPS1_LABEL=Frankfurt
